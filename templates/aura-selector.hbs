<style>
  .aura-effect-list {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }
  .aura-effect-btn {
    display: flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.5em 1em;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
  }
  .aura-effect-img {
    width: 24px;
    height: 24px;
    border: 1px solid #999;
    border-radius: 3px;
    object-fit: cover;
    flex: 0 0 24px;
  }
  .aura-effect-label {
    flex: 1 1 auto;
    text-align: left;
  }
</style>

<section class="aura-effect-list">
  {{#each effects}}
    <button type="button" class="aura-effect-btn" data-action="selectAura" data-effect-id="{{id}}">
      <img class="aura-effect-img" src="{{img}}">
      <span class="aura-effect-label">{{name}}</span>
    </button>
  {{/each}}
</section>
